generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Snack {
  id          String   @id @default(uuid())
  snack       String
  name        String
  description String
  image       String
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
